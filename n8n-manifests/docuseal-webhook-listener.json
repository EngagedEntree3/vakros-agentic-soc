    {
      "parameters": {
        "jsCode": "// Validate DocuSeal webhook signature\nconst crypto = require('crypto');\nconst secret = $env.DOCUSEAL_WEBHOOK_SECRET;\nconst signature = $input.item.json.headers?.['x-docuseal-signature'];\nconst body = JSON.stringify($input.item.json.body);\n\nif (secret && signature) {\n  const expected = crypto\n    .createHmac('sha256', secret)\n    .update(body)\n    .digest('hex');\n  if (signature !== expected) {\n    throw new Error('Invalid DocuSeal webhook signature \u2014 request rejected');\n  }\n}\n\n// Normalise payload\nconst payload = $input.item.json.body;\nreturn [{\n  json: {\n    event_type:     payload.event_type,\n    submission_id:  payload.data?.submission?.id,\n    submitter_id:   payload.data?.submitter?.id,\n    submitter_email: payload.data?.submitter?.email,\n    tenant_id:      payload.data?.submission?.metadata?.tenant_id,\n    status:         payload.data?.submission?.status,\n    completed_at:   payload.data?.submission?.completed_at ?? null,\n    viewed_at:      payload.data?.submission?.viewed_at ?? null,\n    declined_at:    payload.data?.submission?.declined_at ?? null,\n    raw:            payload\n  }\n}];"
      },
      "id": "node-validate-parse",
      "name": "Validate & Parse",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ]
    },
    {
